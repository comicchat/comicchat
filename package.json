{
  "name": "comic-chat-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A faithful web port of Microsoft Comic Chat (1996-1998)",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "extract-art": "node tools/extract-avb.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "check": "npm run typecheck && npm run lint",
    "prepare": "husky"
  },
  "dependencies": {
    "98.css": "^0.1.20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript/native": "npm:typescript@^7.0.2",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^6.0.0"
  }
}
